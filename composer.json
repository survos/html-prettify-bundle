{
    "name": "survos/html-prettify-bundle",
    "description": "format HTML",
    "keywords": [
        "symfony-ux",
        "symfony6"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "gajus/dindent": "^2.0",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "twig/twig": "^3.4",
        "symfony/options-resolver": "^8.1",
        "survos/kit-bundle": "^2.5"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\HtmlPrettifyBundle\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.6-dev"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse"
    }
}